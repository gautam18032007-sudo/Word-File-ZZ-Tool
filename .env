# ZenZebra Contract Generator — environment config
#
# LOCAL DEV: this file is loaded automatically (web/instrumentation.ts reads
# it from one directory above web/). Never commit real values — see
# .env.example for the vars to copy into Vercel's dashboard.
#
# VERCEL: set these same variables in Project Settings → Environment Variables.
# Vercel injects them into process.env directly — no .env file is used there.

# ── Google Sheet IDs ──────────────────────────────────────────────────────────
# Paste just the sheet ID (from the URL) or a full URL — both work.
GOOGLE_BRAND_SHEET_ID=1Gxw2YSeTHNvOsAyYzK13Z_SeZbatlktNoXyzRjTF-yI
GOOGLE_EMPLOYEE_SHEET_ID=1wyfsP44k3hM3PWMqxeKsaTt7TwuwM4VkPuuauTI9gto

# ── Google auth for PRIVATE sheets (optional) ──────────────────────────────────
# Only needed if a sheet is NOT shared "Anyone with the link — Viewer".
# Local dev: place a service account key at ./credentials.json instead (gitignored).
# Vercel: credentials.json is never deployed — set this var instead, with the
# full service-account JSON (or its base64 encoding) as the value.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Brand Sheet Header Names ───────────────────────────────────────────────────
BRAND_HEADER_LEGAL_NAME=Brand Name
BRAND_HEADER_BRAND_CATEGORY=Brand Category
BRAND_HEADER_ADDRESS=Address
BRAND_HEADER_EMAIL=Email
BRAND_HEADER_PHONE=Phone
BRAND_HEADER_CONTACT_PERSON=Contact Person

# ── Employee Sheet Header Names ────────────────────────────────────────────────
EMPLOYEE_HEADER_NAME=Full Name
EMPLOYEE_HEADER_FATHER_NAME=Father's Name
EMPLOYEE_HEADER_ADDRESS=Address
EMPLOYEE_HEADER_EMAIL=Email Address
EMPLOYEE_HEADER_PHONE=Phone Number
EMPLOYEE_HEADER_PAN=PAN Number
EMPLOYEE_HEADER_AADHAR=Aadhar Number
EMPLOYEE_HEADER_DESIGNATION=Designation
EMPLOYEE_HEADER_DEPARTMENT=Department
EMPLOYEE_HEADER_GENDER=Gender

# ── Contract Number Prefix ────────────────────────────────────────────────────
CONTRACT_PREFIX=ZZ

# ── LibreOffice (for PDF generation) ─────────────────────────────────────────
# Local dev only. Vercel's serverless runtime has no LibreOffice binary — PDF
# conversion is best-effort and is skipped automatically there (DOCX is still
# generated; pdfName comes back null). Do not set this var on Vercel.
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
