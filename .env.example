# ZenZebra Contract Generator — copy these into Vercel Project Settings →
# Environment Variables (or into a local .env at the repo root for dev).
# See PROJECT_REPORT.md § Vercel deployment for what each one is for.

# ── Google Sheet IDs (required) ────────────────────────────────────────────────
GOOGLE_BRAND_SHEET_ID=
GOOGLE_EMPLOYEE_SHEET_ID=

# ── Google auth for PRIVATE sheets (optional — skip if sheets are public) ─────
# Full service-account JSON key, or its base64 encoding, as a single value.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Brand Sheet Header Names (must match your Google Form's column headers) ──
BRAND_HEADER_LEGAL_NAME=Brand Name
BRAND_HEADER_BRAND_CATEGORY=Brand Category
BRAND_HEADER_ADDRESS=Address
BRAND_HEADER_EMAIL=Email
BRAND_HEADER_PHONE=Phone
BRAND_HEADER_CONTACT_PERSON=Contact Person

# ── Employee Sheet Header Names (must match your Google Form's column headers) ─
EMPLOYEE_HEADER_NAME=Full Name
EMPLOYEE_HEADER_FATHER_NAME=Father's Name
EMPLOYEE_HEADER_ADDRESS=Address
EMPLOYEE_HEADER_EMAIL=Email Address
EMPLOYEE_HEADER_PHONE=Phone Number
EMPLOYEE_HEADER_PAN=PAN Number
EMPLOYEE_HEADER_AADHAR=Aadhar Number
EMPLOYEE_HEADER_DESIGNATION=Designation
EMPLOYEE_HEADER_DEPARTMENT=Department
EMPLOYEE_HEADER_GENDER=Gender

# ── Contract Number Prefix ────────────────────────────────────────────────────
CONTRACT_PREFIX=ZZ

# ── LibreOffice (local dev only — do NOT set on Vercel) ───────────────────────
# Vercel has no LibreOffice binary; PDF conversion is skipped automatically
# there (DOCX generation still works).
LIBREOFFICE_PATH=

# ── LOR Module Configuration ───────────────────────────────────────────────────
GOOGLE_LOR_SHEET_ID=
GOOGLE_LOR_SHEET_GID=

# Ollama & Qwen Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_LOR=qwen3:32b
OLLAMA_MODEL_EMPLOYEE=qwen3:14b
OLLAMA_MODEL_BRAND=qwen3:14b
OLLAMA_MODEL_CERTIFICATE=qwen3:14b
